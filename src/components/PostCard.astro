---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, category, thumbnail, description } = post.data;

const dateStr = new Date(date).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card" data-category={category}>
  <a href={`/posts/${post.slug}`}>
    <div class="thumbnail">
      {thumbnail
        ? <img src={thumbnail} alt={title} loading="lazy" />
        : <div class="thumbnail-placeholder" />
      }
    </div>
    <div class="card-body">
      <div class="meta">
        <span class={`category-tag ${category}`}>
          {category === 'works' ? 'Works' : 'Thoughts'}
        </span>
        <time datetime={new Date(date).toISOString()}>{dateStr}</time>
      </div>
      <h2>{title}</h2>
      <p class="description">{description}</p>
    </div>
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--color-border);
    background: #fff;
    transition: border-color 0.25s, transform 0.25s;
    overflow: hidden;
  }

  .post-card:hover {
    border-color: #bbb;
    transform: translateY(-3px);
  }

  .post-card a {
    display: block;
    color: inherit;
  }

  .thumbnail {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f2f1ef;
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-card:hover .thumbnail img {
    transform: scale(1.04);
  }

  .thumbnail-placeholder {
    width: 100%;
    height: 100%;
    background: #eeece8;
  }

  .card-body {
    padding: 20px 22px 24px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .category-tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid;
  }

  .category-tag.works {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .category-tag.thoughts {
    border-color: var(--color-text-secondary);
    color: var(--color-text-secondary);
  }

  time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-meta);
  }

  h2 {
    font-size: 0.975rem;
    font-weight: 400;
    margin-bottom: 8px;
    line-height: 1.6;
    color: var(--color-text);
  }

  .description {
    font-size: 0.825rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
