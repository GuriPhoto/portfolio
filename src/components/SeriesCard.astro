---
import type { CollectionEntry } from 'astro:content';

interface Props {
  seriesName: string;
  posts: CollectionEntry<'posts'>[];
  href: string;
}

const { seriesName, posts, href } = Astro.props;
const thumbnail = posts[0]?.data.thumbnail;
---

<a class="series-card" href={href}>
  <div class="image">
    {thumbnail
      ? <img src={thumbnail} alt={seriesName} loading="lazy" />
      : <div class="placeholder" />
    }
  </div>
  <div class="info">
    <h3>{seriesName}</h3>
    <span class="count">{posts.length}点</span>
  </div>
</a>

<style>
  .series-card {
    display: block;
    color: inherit;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s;
  }

  .series-card:hover {
    border-color: #bbb;
    transform: translateY(-3px);
  }

  .image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f2f1ef;
  }

  .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .series-card:hover .image img {
    transform: scale(1.04);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: #eeece8;
  }

  .info {
    padding: 16px 20px 20px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .count {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-meta);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
