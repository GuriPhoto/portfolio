---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, date, category, tags, series, description } = post.data;

const dateStr = new Date(date).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabel = category === 'works' ? 'Works' : 'Thoughts';
const backHref = category === 'works' ? '/works' : '/thoughts';
const backLabel = category === 'works' ? 'Works' : 'Thoughts';
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <div class="post-header-wrap">
      <nav class="back-nav">
        <a href={backHref}>← {backLabel}</a>
      </nav>

      <header class="post-header">
        <div class="meta">
          <span class={`category-tag ${category}`}>{categoryLabel}</span>
          {series && <span class="series-label">{series}</span>}
          <time datetime={new Date(date).toISOString()}>{dateStr}</time>
        </div>
        <h1>{title}</h1>
        <p class="lead">{description}</p>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </header>
    </div>

    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    padding-bottom: var(--spacing-xxl);
  }

  .post-header-wrap {
    padding-top: var(--spacing-lg);
  }

  .back-nav {
    margin-bottom: var(--spacing-lg);
  }

  .back-nav a {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--color-text-meta);
    transition: color 0.2s;
  }

  .back-nav a:hover {
    color: var(--color-text);
  }

  .post-header {
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-xl);
  }

  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .category-tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border: 1px solid;
  }

  .category-tag.works {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .category-tag.thoughts {
    border-color: var(--color-text-secondary);
    color: var(--color-text-secondary);
  }

  .series-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-meta);
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 400;
    line-height: 1.45;
    margin-bottom: 16px;
    letter-spacing: 0.02em;
  }

  .lead {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.85;
    margin-bottom: 16px;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: var(--color-text-secondary);
    padding: 3px 10px;
    border: 1px solid var(--color-border);
  }

  /* ── Markdown content ── */
  .post-content :global(h2) {
    font-size: 1.15rem;
    font-weight: 400;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--color-border);
    letter-spacing: 0.03em;
  }

  .post-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 400;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .post-content :global(p) {
    font-size: 1rem;
    line-height: 1.95;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .post-content :global(img) {
    width: 100%;
    margin: var(--spacing-xl) 0;
    display: block;
  }

  .post-content :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border);
    transition: text-decoration-color 0.2s;
  }

  .post-content :global(a:hover) {
    text-decoration-color: var(--color-text);
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: var(--spacing-md);
    margin: var(--spacing-lg) 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(li) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 4px;
  }

  @media (max-width: 640px) {
    h1 { font-size: 1.4rem; }
    .post-header {
      padding-bottom: var(--spacing-lg);
      margin-bottom: var(--spacing-lg);
    }
    .post-header-wrap { padding-top: var(--spacing-md); }
  }
</style>
