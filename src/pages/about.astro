---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="アーティストステートメントとプロフィール">
  <div class="container">
    <section class="page-header">
      <h1>About</h1>
    </section>

    <div class="about-grid">
      <div class="image-col">
        <div class="image-placeholder">
          <span>Representative Work</span>
        </div>
      </div>

      <div class="text-col">
        <section class="section">
          <h2>Artist Statement</h2>
          <div class="statement-body">
            <p>
              [アーティストステートメントをここに記述します。あなたの写真に対する姿勢、テーマ、制作上の考え方などを自由に書いてください。]
            </p>
            <p>
              [例：被写体との距離感、光と影の使い方、あるいは写真というメディアそのものへの問いかけ——そういった要素が、あなたの作品世界を形作っているはずです。それをここで言葉にしてみてください。]
            </p>
          </div>
        </section>

        <section class="section">
          <h2>Profile</h2>
          <dl class="profile-list">
            <div class="profile-row">
              <dt>Name</dt>
              <dd>[お名前]</dd>
            </div>
            <div class="profile-row">
              <dt>Base</dt>
              <dd>[活動拠点]</dd>
            </div>
            <div class="profile-row">
              <dt>Exhibition</dt>
              <dd>[主な展示歴をここに記述します]</dd>
            </div>
            <div class="profile-row">
              <dt>Contact</dt>
              <dd>[連絡先・SNSリンクなど]</dd>
            </div>
          </dl>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    padding-bottom: var(--spacing-xxl);
  }

  .page-header {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-xl);
  }

  h1 {
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: 0.12em;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .image-placeholder {
    aspect-ratio: 3 / 4;
    background: #eeece8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder span {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--color-text-meta);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section {
    margin-bottom: var(--spacing-xl);
  }

  .section:last-child {
    margin-bottom: 0;
  }

  h2 {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-meta);
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--color-border);
  }

  .statement-body p {
    font-size: 0.975rem;
    line-height: 1.95;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .statement-body p:last-child {
    margin-bottom: 0;
  }

  .profile-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .profile-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--spacing-sm);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .profile-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  dt {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-meta);
    padding-top: 3px;
  }

  dd {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .image-col {
      max-width: 280px;
    }

    h1 { font-size: 1.6rem; }
    .page-header { padding: var(--spacing-lg) 0; }
  }
</style>
