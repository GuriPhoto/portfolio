---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const thoughtsPosts = allPosts
  .filter(p => p.data.category === 'thoughts')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(thoughtsPosts.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title="Thoughts" description="思考・テキストアーカイブ">
  <div class="container">
    <section class="page-header">
      <h1>Thoughts</h1>
      <p class="subtitle">思考・テキストアーカイブ</p>
    </section>

    {allTags.length > 0 && (
      <div class="tags-bar">
        <button class="tag-btn active" data-tag="all">すべて</button>
        {allTags.map(tag => (
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    )}

    <ul class="posts-list">
      {thoughtsPosts.map(post => {
        const dateStr = new Date(post.data.date).toLocaleDateString('ja-JP', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li class="post-item" data-tags={post.data.tags.join(',')}>
            <a href={`/posts/${post.slug}`}>
              <div class="post-meta">
                <time datetime={new Date(post.data.date).toISOString()}>{dateStr}</time>
                <div class="post-tags">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <h2>{post.data.title}</h2>
              <p class="excerpt">{post.data.description}</p>
            </a>
          </li>
        );
      })}
    </ul>

    {thoughtsPosts.length === 0 && (
      <p class="empty">投稿はまだありません。</p>
    )}
  </div>
</BaseLayout>

<script>
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLElement>('.post-item');

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';

      tagBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      items.forEach(item => {
        const tags = (item.dataset.tags ?? '').split(',').filter(Boolean);
        const show = tag === 'all' || tags.includes(tag);
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    padding-bottom: var(--spacing-xxl);
  }

  .page-header {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  h1 {
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }

  .subtitle {
    font-family: var(--font-sans);
    font-size: 0.825rem;
    color: var(--color-text-meta);
    letter-spacing: 0.06em;
  }

  .tags-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: var(--spacing-lg);
  }

  .tag-btn {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    padding: 5px 14px;
    border: 1px solid var(--color-border);
    background: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: all 0.2s;
  }

  .tag-btn:hover,
  .tag-btn.active {
    border-color: var(--color-text);
    background: var(--color-text);
    color: #fff;
  }

  .posts-list {
    list-style: none;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item a {
    display: block;
    padding: 28px 0;
    color: inherit;
    transition: opacity 0.2s;
  }

  .post-item a:hover {
    opacity: 0.65;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-meta);
  }

  .post-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: var(--color-text-secondary);
    padding: 2px 9px;
    border: 1px solid var(--color-border);
  }

  h2 {
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.55;
    margin-bottom: 8px;
  }

  .excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .empty {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-meta);
    padding: var(--spacing-xl) 0;
    text-align: center;
  }

  @media (max-width: 640px) {
    h1 { font-size: 1.6rem; }
    .page-header { padding: var(--spacing-lg) 0; }
    .post-item a { padding: 22px 0; }
  }
</style>
